{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "CI",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_STORYBOOK_URL",
    "NEXT_PUBLIC_REGISTRY_URL",
    "NEXT_PUBLIC_GITHUB_URL",
    "NEXT_PUBLIC_PLAUSIBLE_DOMAIN",
    "NEXT_PUBLIC_PLAUSIBLE_URL",
    "NEXT_PUBLIC_GTM_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "storybook-static/**", "!.next/cache/**"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.json", "tsconfig.json", "package.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "eslint.config.mjs"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "vitest.config.ts"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "vitest.config.ts"]
    },
    "e2e": {
      "dependsOn": ["build"],
      "outputs": ["playwright-report/**"],
      "inputs": ["e2e/**/*.spec.ts", "playwright.config.ts"]
    },
    "registry": {
      "dependsOn": [],
      "outputs": ["dist/index.json"],
      "inputs": [
        "scripts/build-registry.ts",
        "registry.json",
        "../ui/src/**/*.tsx",
        "../ui/src/**/*.ts"
      ]
    },
    "validate:registry": {
      "dependsOn": ["registry"],
      "outputs": []
    },
    "knip": {
      "dependsOn": [],
      "outputs": []
    },
    "syncpack": {
      "dependsOn": [],
      "outputs": []
    },
    "size": {
      "dependsOn": [],
      "outputs": []
    },
    "format": {
      "dependsOn": [],
      "outputs": [],
      "cache": false
    },
    "format:check": {
      "dependsOn": [],
      "outputs": [],
      "cache": false
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
