{
  "name": "@static-ui/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Static UI core - component schemas and multi-framework code generators",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schemas/*": "./src/schemas/*.ts",
    "./generators/*": "./src/generators/*.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1"
  }
}
