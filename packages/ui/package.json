{
  "name": "@static-ui/ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "The single source of truth for all Static UI components - unstyled, accessible, copy-paste React components built on Base UI and Tailwind CSS.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.tsx",
      "import": "./src/*.tsx",
      "default": "./src/*.tsx"
    }
  },
  "sideEffects": false,
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo 'No build needed - components are source-only'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "base-ui",
    "tailwind",
    "shadcn",
    "copy-paste",
    "static-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anshul563/static-ui.git",
    "directory": "packages/ui"
  },
  "homepage": "https://staticui.online",
  "bugs": {
    "url": "https://github.com/Anshul563/static-ui/issues"
  },
  "author": {
    "name": "Anshul Shakya",
    "url": "https://github.com/Anshul563"
  },
  "license": "MIT",
  "peerDependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19",
    "typescript": "^5"
  },
  "dependencies": {
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "vaul": "^1.1.2"
  }
}
