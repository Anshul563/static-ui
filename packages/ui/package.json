{
  "name": "@static-ui/ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "The single source of truth for all Static UI components - unstyled, accessible, copy-paste React components built on Base UI and Tailwind CSS.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/ui/*.tsx"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo 'No build needed - components are source-only'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "base-ui",
    "tailwind",
    "shadcn",
    "copy-paste"
  ],
  "author": "Anshul Shakya",
  "license": "ISC",
  "peerDependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
