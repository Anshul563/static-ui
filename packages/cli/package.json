{
  "name": "@static-ui/cli",
  "version": "0.1.0",
  "description": "The command-line interface for Static UI - initialize projects, add components, apply themes, and manage your design system across multiple frameworks.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "static-ui": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "static-ui",
    "cli",
    "base-ui",
    "tailwind",
    "components",
    "react",
    "vue",
    "svelte",
    "solid",
    "nextjs",
    "nuxt",
    "astro",
    "remix",
    "shadcn"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anshul563/static-ui.git",
    "directory": "packages/cli"
  },
  "homepage": "https://staticui.online",
  "bugs": {
    "url": "https://github.com/Anshul563/static-ui/issues"
  },
  "author": {
    "name": "Anshul Shakya",
    "url": "https://github.com/Anshul563"
  },
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
