{
  "name": "@static-ui/cli",
  "version": "0.0.9",
  "description": "The command-line interface for Static UI",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "static-ui": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "dev": "tsup src/index.ts --format esm --watch"
  },
  "keywords": [
    "static-ui",
    "cli",
    "base-ui",
    "tailwind"
  ],
  "author": "Anshul Shakya",
  "license": "ISC",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}